{
  "name": "god-is-loving-and-kind-bot",
  "version": "1.0.0",
  "description": "Messenger chatbot that replies 'god is loving and kind' to every message in Messenger groups",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --check 'src/**/*.js' 'test/**/*.js'",
    "format:fix": "prettier --write 'src/**/*.js' 'test/**/*.js'",
    "check": "npm run lint && npm run format && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "messenger",
    "bot",
    "chatbot",
    "facebook"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "express": "^4.21.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5"
  }
}
