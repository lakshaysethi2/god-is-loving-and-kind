# ---------------------------------------------------------------------------
# Messenger Bot — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your real values:
#   cp .env.example .env

# Port the webhook server listens on inside the container.
# Docker Compose maps this to the host port (same value by default).
PORT=3000

# Facebook Messenger Platform  (REQUIRED)
# ---------------------------------------------------------------------------
# VERIFY_TOKEN
#   A secret string of your choice. Facebook sends this during webhook setup
#   to verify that you own the endpoint. Choose something long and random.
VERIFY_TOKEN=changeme_to_a_random_secret_string

# PAGE_ACCESS_TOKEN
#   Generated from your Facebook Page > Settings > Messenger Platform.
#   The bot posts replies using this token on behalf of your page.
PAGE_ACCESS_TOKEN=changeme_to_your_page_access_token

# APP_SECRET
#   Found in your Facebook App dashboard under Settings > Basic.
#   Used to verify incoming webhook signatures (X-Hub-Signature-256) so the
#   bot only processes requests genuinely sent by Facebook.
APP_SECRET=changeme_to_your_app_secret

# GRAPH_API_VERSION
#   Facebook Graph API version to use. Update when Facebook deprecates older
#   versions. Defaults to v21.0.
GRAPH_API_VERSION=v21.0

# ---------------------------------------------------------------------------
# How to get your tokens
# ---------------------------------------------------------------------------
# 1. Create a Facebook App at https://developers.facebook.com
# 2. Add the Messenger product
# 3. Connect your Page to the app
# 4. Generate a Page Access Token in the Messenger settings
# 5. Copy your App Secret from Settings > Basic
# 6. Set VERIFY_TOKEN to any secure random string
# 7. Deploy this bot to a public HTTPS URL (use ngrok for local dev)
# 8. Configure the webhook in your Facebook App dashboard:
#       Callback URL:  https://<your-domain>/webhook
#       Verify Token:  <the VERIFY_TOKEN you chose>
#       Subscription fields:  messages, messaging_postbacks
